# Environment settings
# Copy this file to .env in the project root and set your credentials.
# Compose reads .env for MYSQL_* and uses them for mysql_crm, suitecrm, and phpmyadmin.

MYSQL_ROOT_PASSWORD=suitecrm
MYSQL_USER=suitecrm
MYSQL_PASSWORD=suitecrm
MYSQL_DATABASE=suitecrm

# Public URL of this SuiteCRM instance (e.g. https://testsuitecrm.dev.agoracloud.it).
# Set when behind a reverse proxy / Coolify so route checks and redirects work.
# SITE_URL=https://testsuitecrm.dev.agoracloud.it